---
interface Props {
  src: string;
}

const { src } = Astro.props;
---

<div id="pdf-container" class="w-full">
  <canvas id="pdf-canvas" data-pdf-src={src} class="w-full border border-gray-300 rounded"></canvas>
  <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:justify-center sm:items-center">
    <button id="zoom-out" class="btn btn-secondary">縮小</button>
    <span id="zoom-level" class="px-4 py-2">100%</span>
    <button id="zoom-in" class="btn btn-secondary">拡大</button>
    <button id="zoom-fit" class="btn btn-primary">幅に合わせる</button>
  </div>
  <div class="mt-4 flex justify-center gap-2 items-center">
    <button id="prev-page" class="btn btn-secondary">前ページ</button>
    <span id="page-display" class="px-4 py-2">1 / 1</span>
    <button id="next-page" class="btn btn-secondary">次ページ</button>
  </div>
</div>

<script is:inline>
  const pdfjsVersion = '2.16.105';
  const pdfJsUrl = `https://cdnjs.cloudflare.com/ajax/libs/pdf.js/${pdfjsVersion}/pdf.min.js`;
  const pdfWorkerUrl = `https://cdnjs.cloudflare.com/ajax/libs/pdf.js/${pdfjsVersion}/pdf.worker.min.js`;

  function loadPdfJs() {
    return new Promise((resolve, reject) => {
      if (window.pdfjsLib) {
        return resolve(window.pdfjsLib);
      }

      const script = document.createElement('script');
      script.src = pdfJsUrl;
      script.crossOrigin = 'anonymous';
      script.onload = () => {
        if (window.pdfjsLib) {
          resolve(window.pdfjsLib);
        } else {
          reject(new Error('PDF.js loaded but pdfjsLib is not available'));
        }
      };
      script.onerror = () => reject(new Error('Failed to load PDF.js from CDN'));
      document.head.appendChild(script);
    });
  }

  async function initPdfViewer() {
    const canvas = document.getElementById('pdf-canvas');
    const ctx = canvas?.getContext('2d');
    const zoomOutBtn = document.getElementById('zoom-out');
    const zoomInBtn = document.getElementById('zoom-in');
    const zoomFitBtn = document.getElementById('zoom-fit');
    const prevPageBtn = document.getElementById('prev-page');
    const nextPageBtn = document.getElementById('next-page');
    const zoomLevelSpan = document.getElementById('zoom-level');
    const pageDisplay = document.getElementById('page-display');

    let pdfDoc = null;
    let currentPage = 1;
    let totalPages = 0;
    let scale = 1.0;
    const pdfPath = canvas?.dataset.pdfSrc || '';

    function updateZoomDisplay() {
      if (zoomLevelSpan) {
        zoomLevelSpan.textContent = `${Math.round(scale * 100)}%`;
      }
    }

    function updatePageDisplay() {
      if (pageDisplay) {
        pageDisplay.textContent = `${currentPage} / ${totalPages}`;
      }
    }

    async function renderPage(num) {
      if (!pdfDoc || !ctx || !canvas) return;

      const page = await pdfDoc.getPage(num);
      const viewport = page.getViewport({ scale });

      canvas.height = viewport.height;
      canvas.width = viewport.width;

      const renderContext = {
        canvasContext: ctx,
        viewport,
      };

      await page.render(renderContext).promise;
      currentPage = num;
      updateZoomDisplay();
      updatePageDisplay();
    }

    function zoomIn() {
      scale += 0.25;
      renderPage(currentPage);
    }

    function zoomOut() {
      if (scale > 0.5) {
        scale -= 0.25;
        renderPage(currentPage);
      }
    }

    function zoomToFit() {
      if (!pdfDoc || !canvas?.parentElement) return;

      const containerWidth = canvas.parentElement.clientWidth;
      pdfDoc.getPage(currentPage).then((page) => {
        const viewport = page.getViewport({ scale: 1 });
        scale = containerWidth / viewport.width;
        renderPage(currentPage);
      });
    }

    function prevPage() {
      if (currentPage <= 1) return;
      renderPage(currentPage - 1);
    }

    function nextPage() {
      if (currentPage >= totalPages) return;
      renderPage(currentPage + 1);
    }

    if (zoomOutBtn) zoomOutBtn.addEventListener('click', zoomOut);
    if (zoomInBtn) zoomInBtn.addEventListener('click', zoomIn);
    if (zoomFitBtn) zoomFitBtn.addEventListener('click', zoomToFit);
    if (prevPageBtn) prevPageBtn.addEventListener('click', prevPage);
    if (nextPageBtn) nextPageBtn.addEventListener('click', nextPage);

    if (!pdfPath) return;

    try {
      const pdfjsLib = await loadPdfJs();
      pdfjsLib.GlobalWorkerOptions.workerSrc = pdfWorkerUrl;
      pdfDoc = await pdfjsLib.getDocument(pdfPath).promise;
      totalPages = pdfDoc.numPages;
      updatePageDisplay();
      renderPage(currentPage);
    } catch (error) {
      console.error('Error loading PDF:', error);
    }

    window.addEventListener('resize', () => {
      zoomToFit();
    });
  }

  initPdfViewer();
</script>

<style>
  #pdf-container {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #pdf-canvas {
    max-width: 100%;
    height: auto;
  }
</style>
