ZZ---
import Layout from '~/layouts/PageLayout.astro';
import { client } from '~/lib/microcms';

// 全記事のIDを取得して、ページを事前に生成する
export async function getStaticPaths() {
  const response = await client.get({ 
    endpoint: "blogs",
    queries: { fields: 'id' } 
  });
  return response.contents.map((content: any) => ({
    params: { id: content.id },
  }));
}

const { id } = Astro.params;
const post = await client.get({ endpoint: "blogs", contentId: id });

const metadata = { title: post.title };
---

<Layout metadata={metadata}>
  <article class="mx-auto px-6 py-16 max-w-3xl">
    <header class="mb-8 text-center">
      <h1 class="text-4xl font-bold mb-4">{post.title}</h1>
      <time class="text-gray-500">{post.date?.substring(0, 10)}</time>
    </header>

    {post.eyecatch && (
      <img src={post.eyecatch.url} class="w-full h-auto mb-10 rounded-lg shadow-md" />
    )}

    {/* 本文（リッチエディタの内容）をHTMLとして流し込む */}
    <div class="prose prose-lg max-w-none dark:prose-invert" set:html={post.content} />
    
    <div class="mt-12 text-center">
      <a href="/blog" class="text-primary hover:underline">← 一覧に戻る</a>
    </div>
  </article>
</Layout>
