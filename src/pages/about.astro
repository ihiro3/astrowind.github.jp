---
import Layout from '../layouts/PageLayout.astro';
import Hero from '../components/widgets/Hero.astro';
import Content from '../components/widgets/Content.astro';
import Steps from '../components/widgets/Steps.astro';

const metadata = {
  title: 'プロフィール | 精華町議会 爽風会 公式サイト',
};

const profileImage = 'assets/images/team.jpg';
const heroImage =
  'https://images.unsplash.com/photo-1517021897933-0e0319cfbc28?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80';
---

<Layout metadata={metadata}>
  {/* --- 1. プロフィール冒頭 --- */}
  <Hero
    tagline="Profile"
    image={{
      src: profileImage,
      alt: '爽風会のメンバー',
    }}
  >
    <Fragment slot="title">
      精華町の未来を、<br />
      <span class="text-accent dark:text-white highlight">皆様と共に創る。</span>
    </Fragment>

    <Fragment slot="subtitle">
      爽風会は、精華町の発展と住民の幸せを願い、町政に取り組む議員会派です。代表：岡田三郎、経理責任者：辻井崇余、メンバー：尾崎智、山下芳一
    </Fragment>
  </Hero>

  {/* --- 2. 会派メンバー --- */}
  <Steps
    title="会派メンバー"
    items={[
      {
        title: '代表：岡田三郎',
        description: '精華町議会議員。地域の声を町政に届け、より良い街づくりに尽力します。',
        icon: 'tabler:user-star',
      },
      {
        title: '経理責任者：辻井崇余',
        description: '精華町議会議員。透明性のある町政運営と財政健全化を推進します。',
        icon: 'tabler:calculator',
      },
      {
        title: 'メンバー：尾崎智',
        description: '精華町議会議員。子育て・教育環境の充実に重点を置いて活動します。',
        icon: 'tabler:school',
      },
      {
        title: 'メンバー：山下芳一',
        description: '精華町議会議員。高齢者福祉と防災対策の強化に取り組みます。',
        icon: 'tabler:heart-handshake',
      },
    ]}
  />

  {/* --- 3. 会派の理念 --- */}
  <Content
    isReversed
    title="会派の理念"
    subtitle="爽風会が目指す町政"
    items={[
      {
        title: '住民参加型の町政',
        description: '住民の声を真摯に聴き、町政に反映させることで、開かれた議会運営を目指します。',
        icon: 'tabler:users',
      },
      {
        title: '透明性と説明責任',
        description: '議会活動の情報を積極的に公開し、住民の皆様に分かりやすく説明します。',
        icon: 'tabler:eye',
      },
      {
        title: '地域の課題解決',
        description: '少子高齢化、防災、経済活性化など、地域が直面する課題に実効性のある対策を提案します。',
        icon: 'tabler:target',
      },
    ]}
    image={{
      src: heroImage,
      alt: '精華町の風景',
    }}
  />
</Layout>
