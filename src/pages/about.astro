---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';

const metadata = {
  title: 'プロフィール | 山下○○ 公式サイト',
};
---

<Layout metadata={metadata}>
  {/* --- 1. プロフィール冒頭 --- */}
  <Hero
    tagline="Profile"
    image={{
      src: '~/assets/images/profile-portrait.jpg', // ご自身の写真パスに書き換えてください
      alt: '山下○○の近影',
    }}
  >
    <Fragment slot="title">
      地域の未来を、<br />
      <span class="text-accent dark:text-white highlight">皆様と共に創る。</span>
    </Fragment>

    <Fragment slot="subtitle">
      私は、この街で生まれ育ち、地域の皆様の温かさに支えられてきました。今度は私が、市政という場から恩返しをする番です。
    </Fragment>
  </Hero>

  {/* --- 2. 略歴（タイムライン形式） --- */}
  <Steps
    title="歩みと経歴"
    items={[
      {
        title: '誕生・学生時代',
        description: '19XX年、〇〇市生まれ。〇〇市立〇〇小学校、〇〇中学校を卒業。',
        icon: 'tabler:school',
      },
      {
        title: '民間企業での経験',
        description: '大学卒業後、〇〇株式会社に入社。営業職として現場の声を聴く大切さを学びました。',
        icon: 'tabler:briefcase',
      },
      {
        title: '政治の道へ',
        description: '地域の課題を解決したいという想いから、市議会議員に初当選。現在○期目。',
        icon: 'tabler:user-star',
      },
    ]}
  />

  {/* --- 3. 人となり（趣味・家族など） --- */}
  <Content
    isReversed
    title="人となり"
    subtitle="政治の場を離れた、一市民としての私"
    items={[
      {
        title: '家族構成',
        description: '妻と二人の子供（20代）の4人家族。',
        icon: 'tabler:users',
      },
      {
        title: '趣味',
        description: 'プロ野球観戦が趣味です。特にNPBの熱い試合には元気をもらっています。',
        icon: 'tabler:ball-baseball',
      },
      {
        title: '座右の銘',
        description: '「一念通天」。信念を持って取り組めば、必ず道は開けると信じています。',
        icon: 'tabler:quote',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1517021897933-0e0319cfbc28?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80',
      alt: 'イメージ画像',
    }}
  />
</Layout>