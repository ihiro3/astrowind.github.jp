---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';

const metadata = {
  title: '山下○○ 公式サイト | 〇〇市議会議員',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  {/* --- 1. ヒーローセクション（サイトの顔） --- */}
  <Hero
    actions={[
      { variant: 'primary', text: '活動報告を見る', href: '/blog' },
      { text: 'お問い合わせ', href: '/contact' },
    ]}
    image={{ src: '~/assets/images/hero.jpg', alt: '山下○○の近影' }}
  >
    <Fragment slot="title">
      地域と共に歩む、<br />
      <span class="text-accent dark:text-white highlight">山下○○</span> の公式サイト
    </Fragment>

    <Fragment slot="subtitle">
      皆様の声を市政に届け、より良い街づくりを。最新の活動状況や政策についてお伝えします。
    </Fragment>
  </Hero>

  {/* --- 2. 政策提言セクション（3本柱） --- */}
  <Features2
    id="policy"
    title="政策提言"
    subtitle="地域の未来を創る、3つの重点政策"
    items={[
      {
        title: '子育て・教育環境の充実',
        description: '待機児童対策の継続と、学校施設の老朽化対策を推進。ICT教育の導入支援で、次世代を担う子供たちを育みます。',
        icon: 'tabler:school',
      },
      {
        title: '高齢者が安心して暮らせる街へ',
        description: '地域包括ケアシステムの強化と移動手段の確保。孤独死ゼロを目指す見守り活動を強力に支援します。',
        icon: 'tabler:heart-handshake',
      },
      {
        title: '地元経済の活性化と防災対策',
        description: '中小企業のDX化支援とハザードマップの再点検。災害に強く、活気ある商店街の再生に取り組みます。',
        icon: 'tabler:shield-check',
      },
    ]}
  />

  {/* --- 3. 最新の活動報告（自動でブログ記事を表示） --- */}
  <BlogLatestPosts
    title="最新の活動報告"
    information={`日々の議員活動や市政の情報を随時更新しています。ぜひご覧ください。`}
  />

</Layout>