---
import Layout from '../layouts/PageLayout.astro';
import Hero from '../components/widgets/Hero.astro';
import Features2 from '../components/widgets/Features2.astro';
import BlogLatestPosts from '../components/widgets/BlogLatestPosts.astro';
import Content from '../components/widgets/Content.astro';

const metadata = {
  title: '精華町議会 爽風会 公式サイト',
  ignoreTitleTemplate: true,
};

const heroImage = 'assets/images/hero.jpg';
const policyImage = 'https://images.unsplash.com/photo-1488521787991-ed7bbaae773c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80';
---

<Layout metadata={metadata}>
  {/* --- 1. ヒーローセクション（サイトの顔） --- */}
  <Hero
    actions={[
      { variant: 'primary', text: '活動報告を見る', href: '/blog' },
      { text: 'お問い合わせ', href: '/contact' },
    ]}
    image={{ src: heroImage, alt: '爽風会のメンバー' }}
  >
    <Fragment slot="title">
      精華町の未来を切り拓く、<br />
      <span class="text-accent dark:text-white highlight">爽風会</span> の公式サイト
    </Fragment>

    <Fragment slot="subtitle">
      皆様の声を町政に届け、より良い街づくりを。代表：岡田三郎、経理責任者：辻井崇余、メンバー：尾崎智、山下芳一
    </Fragment>
  </Hero>

  {/* --- 2. 政策提言セクション（3本柱） --- */}
  <Features2
    id="policy"
    title="政策提言"
    subtitle="精華町の未来を創る、3つの重点政策"
    items={[
      {
        title: '子育て・教育環境の充実',
        description:
          '待機児童対策の継続と、学校施設の老朽化対策を推進。ICT教育の導入支援で、次世代を担う子供たちを育みます。',
        icon: 'tabler:school',
      },
      {
        title: '高齢者が安心して暮らせる街へ',
        description: '地域包括ケアシステムの強化と移動手段の確保。孤独死ゼロを目指す見守り活動を強力に支援します。',
        icon: 'tabler:heart-handshake',
      },
      {
        title: '地元経済の活性化と防災対策',
        description: '中小企業のDX化支援とハザードマップの再点検。災害に強く、活気ある商店街の再生に取り組みます。',
        icon: 'tabler:shield-check',
      },
    ]}
    image={{
      src: policyImage,
      alt: '政策提言',
    }}
  />

  {/* --- 3. 最新の活動報告（自動でブログ記事を表示） --- */}
  <BlogLatestPosts
    title="最新の活動報告"
    information={`日々の議員活動や町政の情報を随時更新しています。ぜひご覧ください。`}
  />

  {/* --- 4. 最新情報セクション --- */}
  <Content
    title="最新情報"
    subtitle="爽風会からの重要なお知らせ"
    items={[
      {
        title: '議会活動の更新',
        description: '精華町議会での最新の活動状況を随時更新しています。',
        icon: 'tabler:news',
      },
      {
        title: '政策提言の公開',
        description: '精華町の未来を創る政策提言を積極的に公開しています。',
        icon: 'tabler:file-text',
      },
      {
        title: '地域イベントへの参加',
        description: '地域の皆様との交流を深めるイベントに参加しています。',
        icon: 'tabler:calendar-event',
      },
    ]}
    image={{
      src: policyImage,
      alt: '最新情報',
    }}
  />

  {/* --- 5. イベント情報セクション --- */}
  <Content
    isReversed
    title="イベント情報"
    subtitle="爽風会が主催・参加するイベント"
    items={[
      {
        title: '議会報告会',
        description: '精華町議会での活動報告会を開催します。詳細はお問い合わせください。',
        icon: 'tabler:presentation',
      },
      {
        title: '地域懇談会',
        description: '地域の皆様と意見交換を行う懇談会を企画しています。',
        icon: 'tabler:users',
      },
      {
        title: '町政説明会',
        description: '精華町の町政について分かりやすく説明する会を開催します。',
        icon: 'tabler:info-circle',
      },
    ]}
  />

  {/* --- 6. SNSセクション --- */}
  <Content
    title="SNSで最新情報を受け取る"
    subtitle="爽風会の公式SNSアカウント"
    items={[
      {
        title: 'X（旧Twitter）',
        description: '爽風会の最新情報をリアルタイムでお届けします。',
        icon: 'tabler:brand-x',
        link: '#',
      },
      {
        title: 'Facebook',
        description: '活動写真やイベント情報を公開しています。',
        icon: 'tabler:brand-facebook',
        link: '#',
      },
      {
        title: 'Instagram',
        description: '日々の活動の様子を写真で紹介しています。',
        icon: 'tabler:brand-instagram',
        link: '#',
      },
    ]}
    image={{
      src: heroImage,
      alt: 'SNS',
    }}
  />
</Layout>
